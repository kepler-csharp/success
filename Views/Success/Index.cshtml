@{
    ViewData["Title"] = "Ticket check";
}

<section class="topbar">
    <div>
        <p class="eyebrow">Success Scanner</p>
        <h1>Entry check</h1>
        <p class="subtitle">Check each QR with the main API and show the result.</p>
    </div>
    <div class="clock-box">
        <span id="currentDate">--</span>
        <strong id="currentTime">--:--:--</strong>
    </div>
</section>

<section class="dashboard">
    <div class="panel scanner-panel">
        <div class="panel-header">
            <div>
                <h2>Scan ticket</h2>
                <p>The QR reader works like a keyboard. Scan and send the code.</p>
            </div>
            <span id="apiStatus" class="status online">API ready</span>
        </div>

        <form id="scanForm" autocomplete="off">
            @Html.AntiForgeryToken()
            <label for="scanInput">Ticket code</label>
            <div class="scan-row">
                <i class="fas fa-qrcode"></i>
                <input id="scanInput" name="scanCode" type="text" placeholder="Ex: TICKET-001" autofocus>
                <button type="submit">
                    <i class="fas fa-check"></i>
                    Check
                </button>
            </div>
        </form>

        <div class="actions">
            <button type="button" data-code="SUCCESS-DEMO-OK" class="soft-button demo-button">
                <i class="fas fa-vial"></i>
                Valid demo
            </button>
            <button type="button" data-code="SUCCESS-DEMO-FAIL" class="soft-button demo-button">
                <i class="fas fa-ban"></i>
                Invalid demo
            </button>
            <button type="button" id="clearButton" class="soft-button">
                <i class="fas fa-eraser"></i>
                Clear
            </button>
        </div>
        
    </div>

    <div id="resultCard" class="panel result-panel empty">
        <div id="verdictMark" class="verdict-mark neutral">
            <i class="fas fa-ticket"></i>
        </div>
        <p class="eyebrow">Result</p>
        <h2 id="resultTitle">Waiting for scan</h2>
        <p id="resultMessage">Scan a QR. You will see if the ticket can enter.</p>

        <div id="ticketDetails" class="ticket-details hidden">
            <div class="person-card">
                <img id="clientPhoto" src="" alt="">
                <div>
                    <span>Scanned person</span>
                    <strong id="clientName">--</strong>
                    <small id="clientContact">--</small>
                </div>
            </div>
            <div>
                <span>Event</span>
                <strong id="eventName">--</strong>
            </div>
            <div>
                <span>Place</span>
                <strong id="venueName">--</strong>
            </div>
            <div>
                <span>Show time</span>
                <strong id="showtimeStart">--</strong>
            </div>
            <div>
                <span>Seat</span>
                <strong id="seatNumber">--</strong>
            </div>
            <div>
                <span>Type / status</span>
                <strong id="ticketType">--</strong>
            </div>
            <div>
                <span>Code</span>
                <strong id="ticketCode">--</strong>
            </div>
            <div>
                <span>Checked</span>
                <strong id="scanTime">--</strong>
            </div>
        </div>
    </div>
</section>

<section class="stats-grid">
    <div class="stat-card">
        <span>Scans today</span>
        <strong id="todayCount">0</strong>
    </div>
    <div class="stat-card success">
        <span>Approved</span>
        <strong id="approvedCount">0</strong>
    </div>
    <div class="stat-card danger">
        <span>Rejected</span>
        <strong id="rejectedCount">0</strong>
    </div>
</section>

<section class="panel history-panel">
    <div class="panel-header">
        <div>
            <h2>Last checks</h2>
            <p>Local list of the last QR checks on this screen.</p>
        </div>
    </div>
    <div id="historyList" class="history-list">
        <p class="empty-text">No scans yet.</p>
    </div>
</section>

@section Scripts {
    <script>
        window.ticketUrls = {
            validate: '@Url.Action("ValidateTicket", "Success")'
        };
    </script>
    <script src="~/js/site.js" asp-append-version="true"></script>
}
