@{
    ViewData["Title"] = "Entry control";
}

<section class="topbar">
    <div>
        <p class="eyebrow">Success Tickets</p>
        <h1>Entry control</h1>
    </div>
    <div class="clock-box">
        <span id="currentDate">--</span>
        <strong id="currentTime">--:--:--</strong>
    </div>
</section>

<section class="dashboard">
    <div class="panel">
        <div class="panel-header">
            <div>
                <h2>Scan ticket</h2>
                <p>Scan the ticket QR. You can also type the code if needed.</p>
            </div>
            <span id="apiStatus" class="status online">Ready to check</span>
        </div>

        <form id="scanForm" autocomplete="off">
            @Html.AntiForgeryToken()
            <label for="scanInput">Ticket code</label>
            <div class="scan-row">
                <i class="fas fa-qrcode"></i>
                <input id="scanInput" name="scanCode" type="text" placeholder="Scan or type the code" autofocus inputmode="text" enterkeyhint="done" autocapitalize="off" spellcheck="false">
                <button type="submit">
                    <i class="fas fa-check"></i>
                    Check
                </button>
            </div>
        </form>

        <div class="actions">
            <button type="button" id="clearButton" class="soft-button">
                <i class="fas fa-eraser"></i>
                Clear
            </button>
        </div>

        <div class="camera-panel">
            <div class="camera-header">
                <div>
                    <h3>Phone camera</h3>
                    <p>Read the QR with the device camera and verify it automatically.</p>
                </div>
                <span id="cameraStatus" class="camera-status">Camera off</span>
            </div>

            <div id="qrReader" class="qr-reader"></div>

            <div class="actions">
                <button type="button" id="startCameraButton" class="soft-button">
                    <i class="fas fa-camera"></i>
                    Use camera
                </button>
                <button type="button" id="scanNextButton" class="soft-button hidden">
                    <i class="fas fa-rotate-right"></i>
                    Scan next
                </button>
                <button type="button" id="stopCameraButton" class="soft-button hidden">
                    <i class="fas fa-video-slash"></i>
                    Stop camera
                </button>
            </div>
        </div>
    </div>

    <div id="resultCard" class="panel result-panel">
        <div id="verdictMark" class="verdict-mark">
            <i class="fas fa-ticket"></i>
        </div>
        <p class="eyebrow">Result</p>
        <h2 id="resultTitle">Waiting for scan</h2>
        <p id="resultMessage">Scan a QR to see if the person can enter.</p>

        <div id="ticketDetails" class="ticket-details hidden">
            <div class="person-card">
                <img id="clientPhoto" src="" alt="">
                <div>
                    <span>Person</span>
                    <strong id="clientName">--</strong>
                    <small id="clientContact">--</small>
                </div>
            </div>
            <div>
                <span>Event</span>
                <strong id="eventName">--</strong>
            </div>
            <div>
                <span>Place</span>
                <strong id="venueName">--</strong>
            </div>
            <div>
                <span>Time</span>
                <strong id="showtimeStart">--</strong>
            </div>
            <div>
                <span>Seat</span>
                <strong id="seatNumber">--</strong>
            </div>
            <div>
                <span>Type / status</span>
                <strong id="ticketType">--</strong>
            </div>
            <div>
                <span>Code</span>
                <strong id="ticketCode">--</strong>
            </div>
            <div>
                <span>Checked</span>
                <strong id="scanTime">--</strong>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        window.ticketUrls = {
            validate: '@Url.Action("ValidateTicket", "Success")'
        };
    </script>
    @* Libreria local para leer QR desde la camara del navegador. *@
    <script src="~/lib/html5-qrcode/html5-qrcode.min.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
}
