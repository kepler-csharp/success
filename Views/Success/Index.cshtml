@{
    ViewData["Title"] = "Control de ingreso";
}

<section class="topbar">
    <div>
        <p class="eyebrow">Success Tickets</p>
        <h1>Control de ingreso</h1>
    </div>
    <div class="clock-box">
        <span id="currentDate">--</span>
        <strong id="currentTime">--:--:--</strong>
    </div>
</section>

<section class="dashboard">
    <div class="panel">
        <div class="panel-header">
            <div>
                <h2>Escanear ticket</h2>
                <p>Escanea el QR del ticket. Tambien puedes escribir el codigo si hace falta.</p>
            </div>
            <span id="apiStatus" class="status online">Listo para validar</span>
        </div>

        <form id="scanForm" autocomplete="off">
            @Html.AntiForgeryToken()
            <label for="scanInput">Codigo del ticket</label>
            <div class="scan-row">
                <i class="fas fa-qrcode"></i>
                <input id="scanInput" name="scanCode" type="text" placeholder="Escanea o escribe el codigo" autofocus inputmode="text" enterkeyhint="done" autocapitalize="off" spellcheck="false">
                <button type="submit">
                    <i class="fas fa-check"></i>
                    Validar
                </button>
            </div>
        </form>

        <div class="actions">
            <button type="button" id="clearButton" class="soft-button">
                <i class="fas fa-eraser"></i>
                Limpiar
            </button>
        </div>

        <div class="camera-panel">
            <div class="camera-header">
                <div>
                    <h3>Camara del telefono</h3>
                    <p>Lee el QR con la camara del dispositivo y validalo automaticamente.</p>
                </div>
                <span id="cameraStatus" class="camera-status">Camara apagada</span>
            </div>

            <div id="qrReader" class="qr-reader"></div>

            <div class="actions">
                <button type="button" id="startCameraButton" class="soft-button">
                    <i class="fas fa-camera"></i>
                    Usar camara
                </button>
                <button type="button" id="scanNextButton" class="soft-button hidden">
                    <i class="fas fa-rotate-right"></i>
                    Escanear otro
                </button>
                <button type="button" id="stopCameraButton" class="soft-button hidden">
                    <i class="fas fa-video-slash"></i>
                    Detener camara
                </button>
            </div>
        </div>
    </div>

    <div id="resultCard" class="panel result-panel">
        <div id="verdictMark" class="verdict-mark">
            <i class="fas fa-ticket"></i>
        </div>
        <p class="eyebrow">Resultado</p>
        <h2 id="resultTitle">Esperando escaneo</h2>
        <p id="resultMessage">Escanea un QR para saber si la persona puede ingresar.</p>

        <div id="ticketDetails" class="ticket-details hidden">
            <div class="person-card">
                <img id="clientPhoto" src="" alt="">
                <div>
                    <span>Cliente</span>
                    <strong id="clientName">--</strong>
                    <small id="clientContact">--</small>
                </div>
            </div>
            <div>
                <span>Evento</span>
                <strong id="eventName">--</strong>
            </div>
            <div>
                <span>Lugar</span>
                <strong id="venueName">--</strong>
            </div>
            <div>
                <span>Hora</span>
                <strong id="showtimeStart">--</strong>
            </div>
            <div>
                <span>Asiento</span>
                <strong id="seatNumber">--</strong>
            </div>
            <div>
                <span>Tipo / estado</span>
                <strong id="ticketType">--</strong>
            </div>
            <div>
                <span>Codigo</span>
                <strong id="ticketCode">--</strong>
            </div>
            <div>
                <span>Validado</span>
                <strong id="scanTime">--</strong>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        window.ticketUrls = {
            validate: '@Url.Action("ValidateTicket", "Success")'
        };
    </script>
    @* Libreria local para leer QR desde la camara del navegador. *@
    <script src="~/lib/html5-qrcode/html5-qrcode.min.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
}
