@model success.Models.ErrorViewModel
@{
    ViewData["Title"] = "Could not load";
}

<h1 class="text-danger">Could not load the page.</h1>
<h2 class="text-danger">Try again in a few moments.</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>Support code:</strong> <code>@Model.RequestId</code>
    </p>
}
