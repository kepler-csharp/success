@model success.Models.ErrorViewModel
@{
    ViewData["Title"] = "No se pudo cargar";
}

<h1 class="text-danger">No se pudo cargar la pagina.</h1>
<h2 class="text-danger">Intenta de nuevo en unos momentos.</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>Codigo de soporte:</strong> <code>@Model.RequestId</code>
    </p>
}
