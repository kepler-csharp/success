<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Success Tickets</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true">
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
<aside class="sidebar">
    <div class="brand">
        <div class="brand-icon">
            <i class="fas fa-qrcode"></i>
        </div>
        <div>
            <strong>Success Tickets</strong>
            <span>Entry check</span>
        </div>
    </div>

    <nav class="menu">
        <a href="@Url.Action("Index", "Success")" class="menu-link active">
            <i class="fas fa-ticket"></i>
            <span>Check tickets</span>
        </a>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form">
                @Html.AntiForgeryToken()
                <button type="submit" class="menu-link logout-button">
                    <i class="fas fa-right-from-bracket"></i>
                    <span>Log out</span>
                </button>
            </form>
        }
        else
        {
            <a href="@Url.Action("Login", "Account")" class="menu-link">
                <i class="fas fa-right-to-bracket"></i>
                <span>Login</span>
            </a>
        }
    </nav>
</aside>

<main class="page">
    @RenderBody()
</main>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
